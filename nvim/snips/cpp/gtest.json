  },

  "assert_that": {
    "prefix": "assert_that",
    "body": [
      "ASSERT_THAT(${1:actual}, ${2:::testing::Eq(${3:expected})});$0"
    ],
    "description": "ASSERT_THAT matcher assertion."
  },

  "expect_that": {
    "prefix": "expect_that",
    "body": [
      "EXPECT_THAT(${1:actual}, ${2:::testing::Eq(${3:expected})});$0"
    ],
    "description": "EXPECT_THAT matcher assertion."
  },

  "matcher_p": {
    "prefix": "matcher_p",
    "body": [
      "/**",
      " * @brief ${1:Checks a custom condition with one matcher parameter.}",
      " */",
      "MATCHER_P(${2:HasProperty}, ${3:expected}, \"${4:describes the matcher}\") {",
      "\t// TODO(${5:you}): implement the matcher logic.",
      "\treturn ${6:arg == expected};",
      "}$0"
    ],
    "description": "a documented MATCHER_P skeleton."
  },

  "matcher": {
    "prefix": "matcher",
    "body": [
      "/**",
      " * @brief ${1:Checks a custom condition without extra parameters.}",
      " */",
      "MATCHER(${2:IsValid}, \"${3:describes the matcher}\") {",
      "\t// TODO(${4:you}): implement the matcher logic.",
      "\treturn ${5:arg};",
      "}$0"
    ],
    "description": "a documented MATCHER skeleton."
  }
}
