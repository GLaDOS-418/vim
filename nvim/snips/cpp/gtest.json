  },

  "expect_throw": {
    "prefix": "expect_throw",
    "body": [
      "EXPECT_THROW(${1:expression}, ${2:ExceptionType});$0"
    ],
    "description": "EXPECT_THROW assertion."
  },

  "assert_throw": {
    "prefix": "assert_throw",
    "body": [
      "ASSERT_THROW(${1:expression}, ${2:ExceptionType});$0"
    ],
    "description": "ASSERT_THROW assertion."
  },

  "expect_no_throw": {
    "prefix": "expect_no_throw",
